<Window x:Class="AISPC.Views.OrderStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Изменение статуса заказа" Height="450" Width="600"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        MinHeight="400" MinWidth="550"
        Style="{StaticResource DarkWindow}">
    
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="✏️ Изменение статуса заказа" 
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,25"
                   Foreground="#F0F6FC" HorizontalAlignment="Center"/>
        
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Заказ №:" FontWeight="Bold" Width="120" 
                       Foreground="#F0F6FC" VerticalAlignment="Center"/>
            <TextBlock x:Name="OrderIdText" Text="1001" 
                       Foreground="#58A6FF" FontWeight="SemiBold" VerticalAlignment="Center"/>
        </StackPanel>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Клиент:" FontWeight="Bold" Width="120" 
                       Foreground="#F0F6FC" VerticalAlignment="Center"/>
            <TextBlock x:Name="ClientNameText" Text="ООО Техносфера" 
                       Foreground="#8B949E" VerticalAlignment="Center"/>
        </StackPanel>
        
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,25">
            <TextBlock Text="Текущий статус:" FontWeight="Bold" Width="120" 
                       Foreground="#F0F6FC" VerticalAlignment="Center"/>
            <TextBlock x:Name="CurrentStatusText" Text="В обработке" 
                       Foreground="#FFA657" FontWeight="SemiBold" VerticalAlignment="Center"/>
        </StackPanel>
        
        <StackPanel Grid.Row="4">
            <TextBlock Text="Новый статус:" FontWeight="Bold" Margin="0,0,0,12" 
                       Foreground="#F0F6FC"/>
            <ComboBox x:Name="StatusComboBox" Style="{StaticResource DarkComboBox}">
                <ComboBoxItem Content="Новый"/>
                <ComboBoxItem Content="В обработке"/>
                <ComboBoxItem Content="Сборка"/>
                <ComboBoxItem Content="Тестирование"/>
                <ComboBoxItem Content="Готов"/>
                <ComboBoxItem Content="Доставка"/>
                <ComboBoxItem Content="Завершен"/>
                <ComboBoxItem Content="Отменен"/>
            </ComboBox>
        </StackPanel>
        
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,0">
            <Button Content="💾 Сохранить" Margin="0,0,15,0"
                    Style="{StaticResource DarkButton}"
                    Click="Save_Click"/>
            <Button Content="❌ Отмена"
                    Style="{StaticResource DarkButton}"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>