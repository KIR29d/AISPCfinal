<Page x:Class="AISPC.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Панель управления"
      Style="{StaticResource DarkPage}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="25">
            <TextBlock Text="📊 Панель управления" 
                       Style="{StaticResource DarkTitle}"/>
            
            <!-- Статистические карточки -->
            <Grid Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Карточка заказов -->
                <Border Grid.Column="0" Background="#0078D4" CornerRadius="10" 
                        Padding="20" Margin="0,0,12,0" BorderThickness="1" BorderBrush="#106EBE">
                    <StackPanel>
                        <TextBlock Text="📋" FontSize="32" HorizontalAlignment="Center" 
                                   Foreground="White" Margin="0,0,0,12"/>
                        <TextBlock Text="Активные заказы" Foreground="White" 
                                   FontSize="14" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBlock x:Name="OrdersCountText" Text="12" Foreground="White" 
                                   FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- Карточка компонентов -->
                <Border Grid.Column="1" Background="#2EA043" CornerRadius="10" 
                        Padding="20" Margin="6,0" BorderThickness="1" BorderBrush="#238636">
                    <StackPanel>
                        <TextBlock Text="🛠️" FontSize="32" HorizontalAlignment="Center" 
                                   Foreground="White" Margin="0,0,0,12"/>
                        <TextBlock Text="Компонентов в наличии" Foreground="White" 
                                   FontSize="14" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBlock x:Name="ComponentsCountText" Text="247" Foreground="White" 
                                   FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- Карточка сборок -->
                <Border Grid.Column="2" Background="#FFA657" CornerRadius="10" 
                        Padding="20" Margin="6,0" BorderThickness="1" BorderBrush="#FB8500">
                    <StackPanel>
                        <TextBlock Text="🔨" FontSize="32" HorizontalAlignment="Center" 
                                   Foreground="White" Margin="0,0,0,12"/>
                        <TextBlock Text="Сборок в работе" Foreground="White" 
                                   FontSize="14" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBlock x:Name="AssemblyCountText" Text="5" Foreground="White" 
                                   FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- Карточка клиентов -->
                <Border Grid.Column="3" Background="#8957E5" CornerRadius="10" 
                        Padding="20" Margin="12,0,0,0" BorderThickness="1" BorderBrush="#7C3AED">
                    <StackPanel>
                        <TextBlock Text="👥" FontSize="32" HorizontalAlignment="Center" 
                                   Foreground="White" Margin="0,0,0,12"/>
                        <TextBlock Text="Всего клиентов" Foreground="White" 
                                   FontSize="14" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBlock x:Name="ClientsCountText" Text="89" Foreground="White" 
                                   FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
            
            <!-- Быстрые действия -->
            <TextBlock Text="⚡ Быстрые действия" FontSize="20" FontWeight="Bold" 
                       Margin="0,0,0,20" Foreground="#F0F6FC"/>
            
            <StackPanel Orientation="Horizontal" Margin="0,0,0,35">
                <Button Content="➕ Новый заказ" 
                        Style="{StaticResource DarkButton}"
                        Margin="0,0,15,0"
                        Click="NewOrder_Click"/>
                <Button Content="🛠️ Добавить компонент" 
                        Style="{StaticResource DarkButton}"
                        Margin="0,0,15,0"
                        Click="AddComponent_Click"/>
                <Button Content="👤 Новый клиент" 
                        Style="{StaticResource DarkButton}"
                        Margin="0,0,15,0"
                        Click="NewClient_Click"/>
                <Button Content="🔨 Новая задача сборки" 
                        Style="{StaticResource DarkButton}"
                        Click="NewAssemblyTask_Click"/>
            </StackPanel>
            
            <!-- Последние заказы -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="📋 Последние заказы" FontSize="20" FontWeight="Bold" 
                           Margin="0,0,0,20" Foreground="#F0F6FC"/>
                
                <Button Grid.Column="1" Content="🔄 Обновить" 
                        Style="{StaticResource DarkButton}"
                        Margin="0,0,0,20"
                        Click="RefreshData_Click"/>
            </Grid>
            
            <Border Style="{StaticResource DarkBorder}">
                <DataGrid x:Name="RecentOrdersGrid" 
                          Style="{StaticResource DarkDataGrid}"
                          ColumnHeaderStyle="{StaticResource DarkDataGridColumnHeader}"
                          RowStyle="{StaticResource DarkDataGridRow}"
                          CellStyle="{StaticResource DarkDataGridCell}"
                          MouseDoubleClick="RecentOrdersGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="№ Заказа" Binding="{Binding Id}" Width="100"/>
                        <DataGridTextColumn Header="Клиент" Binding="{Binding ClientName}" Width="200"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="150"/>
                        <DataGridTextColumn Header="Сумма" Binding="{Binding TotalAmount, StringFormat=C}" Width="120"/>
                        <DataGridTextColumn Header="Дата" Binding="{Binding OrderDate, StringFormat=dd.MM.yyyy}" Width="120"/>
                        <DataGridTextColumn Header="Приоритет" Binding="{Binding Priority}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>