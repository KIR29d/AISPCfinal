<Page x:Class="AISPC.Views.Pages.ClientsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Клиенты"
      Style="{StaticResource DarkPage}">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="👥 Управление клиентами" 
                   Style="{StaticResource DarkTitle}"/>
        
        <!-- Панель инструментов -->
        <Grid Grid.Row="1" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Grid Width="350" Margin="0,0,15,0" VerticalAlignment="Center">
                    <TextBox x:Name="SearchBox" 
                             Style="{StaticResource DarkTextBox}"
                             GotFocus="SearchBox_GotFocus" 
                             LostFocus="SearchBox_LostFocus"
                             TextChanged="SearchBox_TextChanged"
                             Foreground="#8B949E" 
                             Text="Поиск клиентов..."/>
                </Grid>
                <Button Content="🔍 Найти" 
                        Style="{StaticResource DarkButton}"
                        Click="SearchButton_Click"/>
            </StackPanel>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="➕ Добавить" Margin="0,0,15,0"
                        Style="{StaticResource DarkButton}"
                        Click="AddButton_Click"/>
                <Button Content="✏️ Изменить" Margin="0,0,15,0"
                        Style="{StaticResource DarkButton}"
                        Click="EditButton_Click"/>
                <Button Content="📋 Заказы"
                        Style="{StaticResource DarkButton}"
                        Click="ViewOrdersButton_Click"/>
            </StackPanel>
        </Grid>
        
        <!-- Панель добавления клиента -->
        <Border x:Name="AddClientPanel" Grid.Row="2" Style="{StaticResource DarkBorder}" 
                Margin="0,0,0,25" Visibility="Collapsed">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Заголовок панели -->
                <TextBlock Grid.Row="0" Text="➕ Добавление нового клиента" 
                           FontSize="16" FontWeight="Bold" Margin="0,0,0,20"
                           Foreground="#58A6FF"/>
                
                <!-- Первая строка полей -->
                <Grid Grid.Row="1" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Название/ФИО -->
                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock Text="Название/ФИО:" Foreground="#F0F6FC" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <Grid>
                            <TextBox x:Name="NameTextBox" Style="{StaticResource DarkTextBox}" Height="35"
                                     GotFocus="NameTextBox_GotFocus" LostFocus="NameTextBox_LostFocus"/>
                            <TextBlock x:Name="NamePlaceholder" Text="Введите название или ФИО"
                                       Foreground="#666666" FontSize="14" IsHitTestVisible="False"
                                       Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                    
                    <!-- Тип клиента -->
                    <StackPanel Grid.Column="1" Margin="0,0,15,0">
                        <TextBlock Text="Тип клиента:" Foreground="#F0F6FC" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="ClientTypeComboBox" Style="{StaticResource DarkComboBox}" Height="35"/>
                    </StackPanel>
                    
                    <!-- Телефон -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Телефон:" Foreground="#F0F6FC" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <Grid>
                            <TextBox x:Name="PhoneTextBox" Style="{StaticResource DarkTextBox}" Height="35"
                                     GotFocus="PhoneTextBox_GotFocus" LostFocus="PhoneTextBox_LostFocus"/>
                            <TextBlock x:Name="PhonePlaceholder" Text="Введите телефон"
                                       Foreground="#666666" FontSize="14" IsHitTestVisible="False"
                                       Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Grid>
                
                <!-- Вторая строка полей -->
                <Grid Grid.Row="2" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Email -->
                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock Text="Email:" Foreground="#F0F6FC" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <Grid>
                            <TextBox x:Name="EmailTextBox" Style="{StaticResource DarkTextBox}" Height="35"
                                     GotFocus="EmailTextBox_GotFocus" LostFocus="EmailTextBox_LostFocus"/>
                            <TextBlock x:Name="EmailPlaceholder" Text="Введите email"
                                       Foreground="#666666" FontSize="14" IsHitTestVisible="False"
                                       Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                    
                    <!-- ИНН -->
                    <StackPanel Grid.Column="1" Margin="0,0,15,0">
                        <TextBlock Text="ИНН:" Foreground="#F0F6FC" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <Grid>
                            <TextBox x:Name="INNTextBox" Style="{StaticResource DarkTextBox}" Height="35"
                                     GotFocus="INNTextBox_GotFocus" LostFocus="INNTextBox_LostFocus"/>
                            <TextBlock x:Name="INNPlaceholder" Text="Введите ИНН"
                                       Foreground="#666666" FontSize="14" IsHitTestVisible="False"
                                       Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                    
                    <!-- Адрес -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Адрес:" Foreground="#F0F6FC" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <Grid>
                            <TextBox x:Name="AddressTextBox" Style="{StaticResource DarkTextBox}" Height="35"
                                     GotFocus="AddressTextBox_GotFocus" LostFocus="AddressTextBox_LostFocus"/>
                            <TextBlock x:Name="AddressPlaceholder" Text="Введите адрес"
                                       Foreground="#666666" FontSize="14" IsHitTestVisible="False"
                                       Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Grid>
                
                <!-- Кнопки действий -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="💾 Сохранить" Margin="0,0,15,0"
                            Style="{StaticResource DarkButton}"
                            Click="SaveClient_Click"/>
                    <Button Content="❌ Отмена"
                            Style="{StaticResource DarkButton}"
                            Click="CancelAddClient_Click"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Таблица клиентов -->
        <Border Grid.Row="3" Style="{StaticResource DarkBorder}">
            <DataGrid x:Name="ClientsGrid" 
                      Style="{StaticResource DarkDataGrid}"
                      ColumnHeaderStyle="{StaticResource DarkDataGridColumnHeader}"
                      RowStyle="{StaticResource DarkDataGridRow}"
                      CellStyle="{StaticResource DarkDataGridCell}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                    <DataGridTextColumn Header="Название/ФИО" Binding="{Binding Name}" Width="250"/>
                    <DataGridTextColumn Header="Тип" Binding="{Binding ClientType}" Width="120"/>
                    <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="150"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200"/>
                    <DataGridTextColumn Header="ИНН" Binding="{Binding INN}" Width="120"/>
                    <DataGridTextColumn Header="Дата создания" Binding="{Binding CreatedDate, StringFormat=dd.MM.yyyy}" Width="120"/>
                    <DataGridTextColumn Header="Примечания" Binding="{Binding Notes}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>