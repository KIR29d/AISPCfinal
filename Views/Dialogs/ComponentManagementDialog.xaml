<Window x:Class="AISPC.Views.Dialogs.ComponentManagementDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление компонентами"
        Width="1000" Height="750"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinWidth="900" MinHeight="700"
        Background="#0D1117">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock x:Name="TitleTextBlock" Grid.Row="0" Text="🛠️ Управление компонентами" 
                   FontSize="20" FontWeight="Bold" 
                   Foreground="#F0F6FC" Margin="0,0,0,25"/>

        <!-- Основная форма -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Первая строка полей -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Название -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Название:" Foreground="#F0F6FC" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox x:Name="NameTextBox" Height="40"
                                 Background="#21262D" Foreground="#F0F6FC" BorderBrush="#30363D"
                                 Padding="12,10" FontSize="14" BorderThickness="1"/>
                    </StackPanel>
                    
                    <!-- Категория -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Категория:" Foreground="#F0F6FC" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ComboBox x:Name="CategoryComboBox" Height="40"
                                  Background="#21262D" Foreground="#F0F6FC" BorderBrush="#30363D"
                                  Padding="12,10" FontSize="14" BorderThickness="1"
                                  IsEditable="True">
                            <ComboBoxItem Content="Процессоры"/>
                            <ComboBoxItem Content="Видеокарты"/>
                            <ComboBoxItem Content="Память"/>
                            <ComboBoxItem Content="Накопители"/>
                            <ComboBoxItem Content="Материнские платы"/>
                            <ComboBoxItem Content="Блоки питания"/>
                            <ComboBoxItem Content="Корпуса"/>
                            <ComboBoxItem Content="Охлаждение"/>
                            <ComboBoxItem Content="Периферия"/>
                        </ComboBox>
                    </StackPanel>
                    
                    <!-- Бренд -->
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Бренд:" Foreground="#F0F6FC" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox x:Name="BrandTextBox" Height="40"
                                 Background="#21262D" Foreground="#F0F6FC" BorderBrush="#30363D"
                                 Padding="12,10" FontSize="14" BorderThickness="1"/>
                    </StackPanel>
                </Grid>

                <!-- Вторая строка полей -->
                <Grid Grid.Row="1" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Модель -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Модель:" Foreground="#F0F6FC" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox x:Name="ModelTextBox" Height="40"
                                 Background="#21262D" Foreground="#F0F6FC" BorderBrush="#30363D"
                                 Padding="12,10" FontSize="14" BorderThickness="1"/>
                    </StackPanel>
                    
                    <!-- Цена -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Цена (руб.):" Foreground="#F0F6FC" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox x:Name="PriceTextBox" Height="40"
                                 Background="#21262D" Foreground="#F0F6FC" BorderBrush="#30363D"
                                 Padding="12,10" FontSize="14" BorderThickness="1"/>
                    </StackPanel>
                    
                    <!-- Количество на складе -->
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Количество:" Foreground="#F0F6FC" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox x:Name="StockTextBox" Height="40"
                                 Background="#21262D" Foreground="#F0F6FC" BorderBrush="#30363D"
                                 Padding="12,10" FontSize="14" BorderThickness="1"/>
                    </StackPanel>
                </Grid>

                <!-- Третья строка полей -->
                <Grid Grid.Row="2" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Минимальный остаток -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Мин. остаток:" Foreground="#F0F6FC" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox x:Name="MinStockTextBox" Height="40"
                                 Background="#21262D" Foreground="#F0F6FC" BorderBrush="#30363D"
                                 Padding="12,10" FontSize="14" BorderThickness="1" Text="5"/>
                    </StackPanel>
                    
                    <!-- Активен -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                        <CheckBox x:Name="IsActiveCheckBox" Content="Активен" Margin="0,15,0,0"
                                  Foreground="#F0F6FC" FontWeight="SemiBold" FontSize="14"
                                  IsChecked="True"/>
                    </StackPanel>
                </Grid>

                <!-- Описание и характеристики -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Описание -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Описание:" Foreground="#F0F6FC" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox x:Name="DescriptionTextBox" Height="100"
                                 Background="#21262D" Foreground="#F0F6FC" BorderBrush="#30363D"
                                 Padding="12,10" FontSize="14" BorderThickness="1"
                                 TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                    
                    <!-- Характеристики -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Характеристики:" Foreground="#F0F6FC" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox x:Name="SpecificationsTextBox" Height="100"
                                 Background="#21262D" Foreground="#F0F6FC" BorderBrush="#30363D"
                                 Padding="12,10" FontSize="14" BorderThickness="1"
                                 TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,0">
            <Button Content="Отмена" Width="120" Height="40" Margin="0,0,15,0"
                    Background="#21262D" Foreground="#F0F6FC" BorderBrush="#30363D"
                    FontSize="14" Click="Cancel_Click"/>
            <Button x:Name="SaveButton" Content="Сохранить" Width="120" Height="40"
                    Background="#238636" Foreground="White" BorderBrush="#238636"
                    FontSize="14" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>