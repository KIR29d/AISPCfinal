<Window x:Class="AISPC.Views.Dialogs.UserManagementDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление пользователями" Height="550" Width="700"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        MinHeight="500" MinWidth="650"
        Style="{StaticResource DarkWindow}">
    
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock x:Name="TitleTextBlock" Grid.Row="0" Text="👤 Добавление пользователя" 
                   FontSize="22" FontWeight="Bold" Margin="0,0,0,25"
                   Foreground="#F0F6FC" HorizontalAlignment="Center"/>
        
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Основная информация -->
                <TextBlock Text="Учетные данные" FontSize="16" FontWeight="Bold" 
                           Margin="0,0,0,15" Foreground="#F0F6FC"/>
                
                <Grid Margin="0,0,0,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Логин:" 
                               VerticalAlignment="Center" Margin="0,0,0,15" 
                               Foreground="#F0F6FC" FontWeight="SemiBold"/>
                    <TextBox x:Name="LoginTextBox" Grid.Row="0" Grid.Column="1" 
                             Style="{StaticResource DarkTextBox}" Margin="0,0,0,15"
                             GotFocus="LoginTextBox_GotFocus" LostFocus="LoginTextBox_LostFocus"
                             Foreground="#C9D1D9" Text="Введите логин пользователя"/>
                    
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Пароль:" 
                               VerticalAlignment="Center" Margin="0,0,0,15" 
                               Foreground="#F0F6FC" FontWeight="SemiBold"/>
                    <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,15">
                        <PasswordBox x:Name="PasswordBox" 
                                     Style="{StaticResource DarkPasswordBox}"
                                     GotFocus="PasswordBox_GotFocus" LostFocus="PasswordBox_LostFocus"/>
                        <TextBlock x:Name="PasswordPlaceholder" Text="Введите пароль" 
                                   Foreground="#C9D1D9" IsHitTestVisible="False"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </Grid>
                    
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Роль:" 
                               VerticalAlignment="Center" 
                               Foreground="#F0F6FC" FontWeight="SemiBold"/>
                    <ComboBox x:Name="RoleComboBox" Grid.Row="2" Grid.Column="1" 
                              Style="{StaticResource DarkComboBox}"
                              DisplayMemberPath="Name" SelectedValuePath="Id"/>
                </Grid>
                
                <!-- Статус -->
                <CheckBox x:Name="IsActiveCheckBox" Content="Активный пользователь" 
                          Style="{StaticResource DarkCheckBox}" IsChecked="True" Margin="0,0,0,20"/>
                
                <!-- Предварительный просмотр -->
                <Border Style="{StaticResource DarkBorder}" Padding="15">
                    <StackPanel>
                        <TextBlock Text="👤 Предварительный просмотр" FontSize="14" FontWeight="Bold" 
                                   Margin="0,0,0,10" Foreground="#58A6FF"/>
                        <TextBlock x:Name="PreviewText" Text="Пользователь будет добавлен в систему" 
                                   Foreground="#C9D1D9" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,0">
            <Button x:Name="SaveButton" Content="💾 Добавить пользователя" Margin="0,0,15,0"
                    Style="{StaticResource DarkButton}"
                    Click="Save_Click"/>
            <Button Content="❌ Отмена"
                    Style="{StaticResource DarkButton}"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>