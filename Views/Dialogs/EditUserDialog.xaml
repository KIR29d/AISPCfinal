<Window x:Class="AISPC.Views.Dialogs.EditUserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование пользователя" Height="550" Width="650"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        MinHeight="500" MinWidth="600"
        Style="{StaticResource DarkWindow}">
    
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="✏️ Редактирование пользователя" 
                   FontSize="22" FontWeight="Bold" Margin="0,0,0,25"
                   Foreground="#F0F6FC" HorizontalAlignment="Center"/>
        
        <StackPanel Grid.Row="1">
            <!-- Учетные данные -->
            <TextBlock Text="Учетные данные" FontSize="16" FontWeight="Bold" 
                       Margin="0,0,0,15" Foreground="#F0F6FC"/>
            
            <Grid Margin="0,0,0,25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Логин:" 
                           VerticalAlignment="Center" Margin="0,0,0,15" 
                           Foreground="#F0F6FC" FontWeight="SemiBold"/>
                <TextBox x:Name="LoginTextBox" Grid.Row="0" Grid.Column="1" 
                         Style="{StaticResource DarkTextBox}" Margin="0,0,0,15"
                         Foreground="#F0F6FC"/>
                
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Новый пароль:" 
                           VerticalAlignment="Center" Margin="0,0,0,15" 
                           Foreground="#F0F6FC" FontWeight="SemiBold"/>
                <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,15">
                    <PasswordBox x:Name="PasswordBox" 
                                 Style="{StaticResource DarkPasswordBox}"
                                 GotFocus="PasswordBox_GotFocus" LostFocus="PasswordBox_LostFocus"/>
                    <TextBlock x:Name="PasswordPlaceholder" Grid.Row="1" Grid.Column="1"
                               Text="Оставьте пустым, чтобы не менять"
                               FontSize="13"
                               Foreground="#C9D1D9"
                               Margin="10,8,0,15"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False"
                               Visibility="Visible"/>
                </Grid>
                
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Роль:" 
                           VerticalAlignment="Center" Margin="0,0,0,15"
                           Foreground="#F0F6FC" FontWeight="SemiBold"/>
                <ComboBox x:Name="RoleComboBox" Grid.Row="2" Grid.Column="1" 
                          Style="{StaticResource DarkComboBox}" Margin="0,0,0,15"
                          DisplayMemberPath="Name" SelectedValuePath="Id"/>
                
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Активен:" 
                           VerticalAlignment="Center" 
                           Foreground="#F0F6FC" FontWeight="SemiBold"/>
                <CheckBox x:Name="IsActiveCheckBox" Grid.Row="3" Grid.Column="1" 
                          Content="Пользователь активен" 
                          Foreground="#F0F6FC" VerticalAlignment="Center"/>
            </Grid>
            
            <!-- Предварительный просмотр -->
            <Border Style="{StaticResource DarkBorder}" Padding="15">
                <StackPanel>
                    <TextBlock Text="👤 Предварительный просмотр" FontSize="14" FontWeight="Bold" 
                               Margin="0,0,0,10" Foreground="#58A6FF"/>
                    <TextBlock x:Name="PreviewText" Text="Данные пользователя будут обновлены" 
                               Foreground="#C9D1D9" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>
        
        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Отмена" Width="120" Height="40" Margin="0,0,15,0"
                    Style="{StaticResource DarkButton}" Background="#21262D"
                    Click="Cancel_Click"/>
            <Button Content="Сохранить" Width="120" Height="40"
                    Style="{StaticResource DarkButton}" Background="#238636"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>