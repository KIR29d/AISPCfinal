<Window x:Class="AISPC.Views.Dialogs.ChangeAssemblyStatusDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Изменение статуса задачи сборки" Height="400" Width="550"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        MinHeight="350" MinWidth="500"
        Style="{StaticResource DarkWindow}">
    
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="🔄 Изменение статуса задачи сборки" 
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,20"
                   Foreground="#F0F6FC" HorizontalAlignment="Center"/>
        
        <StackPanel Grid.Row="1">
            <!-- Информация о задаче -->
            <Border Style="{StaticResource DarkBorder}" Padding="15" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="📋 Информация о задаче" FontSize="14" FontWeight="Bold" 
                               Margin="0,0,0,10" Foreground="#58A6FF"/>
                    <TextBlock x:Name="TaskInfoTextBlock" Text="Задача сборки #1" 
                               Foreground="#F0F6FC" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
            
            <!-- Новый статус -->
            <TextBlock Text="Новый статус:" Foreground="#F0F6FC" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <ComboBox x:Name="StatusComboBox" Margin="0,0,0,15" Height="35"
                      Style="{StaticResource DarkComboBox}"
                      SelectionChanged="StatusComboBox_SelectionChanged">
                <ComboBoxItem Content="Ожидает" Style="{StaticResource DarkComboBoxItem}"/>
                <ComboBoxItem Content="В работе" Style="{StaticResource DarkComboBoxItem}"/>
                <ComboBoxItem Content="Завершено" Style="{StaticResource DarkComboBoxItem}"/>
                <ComboBoxItem Content="Приостановлено" Style="{StaticResource DarkComboBoxItem}"/>
                <ComboBoxItem Content="Отменено" Style="{StaticResource DarkComboBoxItem}"/>
            </ComboBox>
            
            <!-- Комментарий -->
            <TextBlock Text="Комментарий к изменению:" Foreground="#F0F6FC" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="CommentTextBox" Height="80" Margin="0,0,0,15"
                     Style="{StaticResource DarkTextBox}"
                     TextWrapping="Wrap" AcceptsReturn="True"
                     Text="Введите комментарий (необязательно)"/>
            
            <!-- Дата завершения (если статус "Завершено") -->
            <TextBlock x:Name="CompletionDateLabel" Text="Дата завершения:" 
                       Foreground="#F0F6FC" FontWeight="SemiBold" Margin="0,0,0,5"
                       Visibility="Collapsed"/>
            <DatePicker x:Name="CompletionDatePicker" Height="35" Margin="0,0,0,15"
                        Style="{StaticResource DarkDatePicker}"
                        Visibility="Collapsed"/>
        </StackPanel>
        
        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Отмена" Width="100" Height="35" Margin="0,0,15,0"
                    Style="{StaticResource DarkButton}" Background="#21262D"
                    Click="Cancel_Click"/>
            <Button Content="Сохранить" Width="100" Height="35"
                    Style="{StaticResource DarkButton}" Background="#238636"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>