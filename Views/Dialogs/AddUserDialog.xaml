<Window x:Class="AISPC.Views.Dialogs.AddUserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление пользователя" Height="550" Width="650"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        MinHeight="500" MinWidth="600"
        Style="{StaticResource DarkWindow}">
    
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="👤 Добавление пользователя" 
                   FontSize="22" FontWeight="Bold" Margin="0,0,0,25"
                   Foreground="#F0F6FC" HorizontalAlignment="Center"/>
        
        <StackPanel Grid.Row="1">
            <!-- Основная информация -->
            <TextBlock Text="Учетные данные" FontSize="16" FontWeight="Bold" 
                       Margin="0,0,0,15" Foreground="#F0F6FC"/>
            
            <Grid Margin="0,0,0,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Логин:" 
                           VerticalAlignment="Center" Margin="0,0,0,15" 
                           Foreground="#F0F6FC" FontWeight="SemiBold"/>
                <TextBox x:Name="LoginTextBox" Grid.Row="0" Grid.Column="1" 
                         Style="{StaticResource DarkTextBox}" Margin="0,0,0,15"
                         GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"
                         Foreground="#C9D1D9" Text="Введите логин пользователя"/>
                
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Пароль:" 
                           VerticalAlignment="Center" Margin="0,0,0,15" 
                           Foreground="#F0F6FC" FontWeight="SemiBold"/>
                <PasswordBox x:Name="PasswordBox" Grid.Row="1" Grid.Column="1" 
                             Style="{StaticResource DarkPasswordBox}" Margin="0,0,0,15"
                             GotFocus="PasswordBox_GotFocus" LostFocus="PasswordBox_LostFocus"/>
                <TextBlock x:Name="PasswordPlaceholder" Grid.Row="1" Grid.Column="1"
                           Text="Введите пароль"
                           FontSize="13"
                           Foreground="#C9D1D9"
                           Margin="10,8,0,15"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"
                           Visibility="Visible"/>
                
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Роль:" 
                           VerticalAlignment="Center" 
                           Foreground="#F0F6FC" FontWeight="SemiBold"/>
                <ComboBox x:Name="RoleComboBox" Grid.Row="2" Grid.Column="1" 
                          Style="{StaticResource DarkComboBox}"
                          DisplayMemberPath="Name" SelectedValuePath="Id"/>
            </Grid>
            
            <!-- Предварительный просмотр -->
            <Border Style="{StaticResource DarkBorder}" Padding="15">
                <StackPanel>
                    <TextBlock Text="👤 Предварительный просмотр" FontSize="14" FontWeight="Bold" 
                               Margin="0,0,0,10" Foreground="#58A6FF"/>
                    <TextBlock x:Name="PreviewText" Text="Пользователь будет добавлен в систему" 
                               Foreground="#C9D1D9" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,0">
            <Button Content="💾 Добавить пользователя" Margin="0,0,15,0"
                    Style="{StaticResource DarkButton}"
                    Click="AddUser_Click"/>
            <Button Content="❌ Отмена"
                    Style="{StaticResource DarkButton}"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>