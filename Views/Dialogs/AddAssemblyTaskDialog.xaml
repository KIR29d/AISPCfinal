<Window x:Class="AISPC.Views.Dialogs.AddAssemblyTaskDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить задачу сборки"
        Width="800" Height="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinHeight="650" MinWidth="750"
        Style="{StaticResource DarkWindow}">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="🔨 Добавить новую задачу сборки" 
                   FontSize="22" FontWeight="Bold" 
                   Foreground="#F0F6FC" Margin="0,0,0,25"
                   HorizontalAlignment="Center"/>

        <!-- Форма -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Информация о заказе -->
                <TextBlock Text="Информация о заказе" FontSize="16" FontWeight="Bold" 
                           Margin="0,0,0,15" Foreground="#F0F6FC"/>
                
                <Grid Margin="0,0,0,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="ID заказа:" 
                               VerticalAlignment="Center" Margin="0,0,0,15" 
                               Foreground="#F0F6FC" FontWeight="SemiBold"/>
                    <TextBox x:Name="OrderIdTextBox" Grid.Row="0" Grid.Column="1" 
                             Style="{StaticResource DarkTextBox}" Margin="0,0,0,15" Height="40"/>
                    
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Приоритет:" 
                               VerticalAlignment="Center" 
                               Foreground="#F0F6FC" FontWeight="SemiBold"/>
                    <ComboBox x:Name="PriorityComboBox" Grid.Row="1" Grid.Column="1" 
                              Style="{StaticResource DarkComboBox}" Height="40">
                        <ComboBoxItem Content="Низкий" Style="{StaticResource DarkComboBoxItem}"/>
                        <ComboBoxItem Content="Обычный" Style="{StaticResource DarkComboBoxItem}" IsSelected="True"/>
                        <ComboBoxItem Content="Высокий" Style="{StaticResource DarkComboBoxItem}"/>
                        <ComboBoxItem Content="Критический" Style="{StaticResource DarkComboBoxItem}"/>
                    </ComboBox>
                </Grid>

                <!-- Информация о сборщике -->
                <TextBlock Text="Информация о сборщике" FontSize="16" FontWeight="Bold" 
                           Margin="0,0,0,15" Foreground="#F0F6FC"/>
                
                <Grid Margin="0,0,0,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="ID сборщика:" 
                               VerticalAlignment="Center" Margin="0,0,0,15" 
                               Foreground="#F0F6FC" FontWeight="SemiBold"/>
                    <TextBox x:Name="AssemblerIdTextBox" Grid.Row="0" Grid.Column="1" 
                             Style="{StaticResource DarkTextBox}" Margin="0,0,0,15" Height="40"/>
                    
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Имя сборщика:" 
                               VerticalAlignment="Center" 
                               Foreground="#F0F6FC" FontWeight="SemiBold"/>
                    <TextBox x:Name="AssemblerNameTextBox" Grid.Row="1" Grid.Column="1" 
                             Style="{StaticResource DarkTextBox}" Height="40"/>
                </Grid>

                <!-- Планирование -->
                <TextBlock Text="Планирование" FontSize="16" FontWeight="Bold" 
                           Margin="0,0,0,15" Foreground="#F0F6FC"/>
                
                <Grid Margin="0,0,0,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="Дата начала:" 
                               VerticalAlignment="Center" 
                               Foreground="#F0F6FC" FontWeight="SemiBold"/>
                    <DatePicker x:Name="StartDatePicker" Grid.Column="1" 
                               Style="{StaticResource DarkDatePicker}" Height="40"/>
                </Grid>

                <!-- Примечания -->
                <TextBlock Text="Примечания" FontSize="16" FontWeight="Bold" 
                           Margin="0,0,0,15" Foreground="#F0F6FC"/>
                
                <TextBox x:Name="NotesTextBox" 
                         Style="{StaticResource DarkTextBox}" Height="100" Margin="0,0,0,20"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         Text="Дополнительные инструкции для сборщика (необязательно)"/>
                
                <!-- Предварительный просмотр -->
                <Border Style="{StaticResource DarkBorder}" Padding="15">
                    <StackPanel>
                        <TextBlock Text="🔨 Предварительный просмотр задачи" FontSize="14" FontWeight="Bold" 
                                   Margin="0,0,0,10" Foreground="#58A6FF"/>
                        <TextBlock x:Name="PreviewText" Text="Задача сборки будет добавлена в очередь" 
                                   Foreground="#C9D1D9" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,0">
            <Button Content="🔨 Добавить задачу" Margin="0,0,15,0"
                    Style="{StaticResource DarkButton}"
                    Click="Add_Click"/>
            <Button Content="❌ Отмена"
                    Style="{StaticResource DarkButton}"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>