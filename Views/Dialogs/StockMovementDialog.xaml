<Window x:Class="AISPC.Views.Dialogs.StockMovementDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Движение товара"
        Width="400" Height="250"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0D1117">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock x:Name="TitleTextBlock" Grid.Row="0" 
                   FontSize="18" FontWeight="Bold" 
                   Foreground="#F0F6FC" Margin="0,0,0,20"/>

        <!-- Форма -->
        <StackPanel Grid.Row="1">
            <!-- Компонент -->
            <TextBlock Text="Компонент:" Foreground="#F0F6FC" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBlock x:Name="ComponentNameTextBlock" Margin="0,0,0,15" 
                       Foreground="#8B949E" FontSize="14"/>

            <!-- Количество -->
            <TextBlock Text="Количество:" Foreground="#F0F6FC" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="QuantityTextBox" Margin="0,0,0,15" Height="35"
                     Background="#21262D" Foreground="#F0F6FC" BorderBrush="#30363D"
                     Padding="10,8" FontSize="14"/>
        </StackPanel>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Отмена" Width="100" Height="35" Margin="0,0,15,0"
                    Background="#21262D" Foreground="#F0F6FC" BorderBrush="#30363D"
                    Click="Cancel_Click"/>
            <Button x:Name="ConfirmButton" Width="100" Height="35"
                    Background="#238636" Foreground="White" BorderBrush="#238636"
                    Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Window>