<Window x:Class="AISPC.Views.Dialogs.AddComponentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление компонента" Height="700" Width="850"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        MinHeight="650" MinWidth="800"
        Style="{StaticResource DarkWindow}">
    
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="🛠️ Добавление компонента" 
                   FontSize="22" FontWeight="Bold" Margin="0,0,0,25"
                   Foreground="#F0F6FC" HorizontalAlignment="Center"/>
        
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Основная информация -->
                <TextBlock Text="Основная информация" FontSize="16" FontWeight="Bold" 
                           Margin="0,0,0,15" Foreground="#F0F6FC"/>
                
                <Grid Margin="0,0,0,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Название:" 
                               VerticalAlignment="Center" Margin="0,0,0,15" 
                               Foreground="#F0F6FC" FontWeight="SemiBold"/>
                    <TextBox x:Name="NameTextBox" Grid.Row="0" Grid.Column="1" 
                             Style="{StaticResource DarkTextBox}" Margin="0,0,0,15"
                             GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"
                             Foreground="#C9D1D9" Text="Введите название компонента"/>
                    
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Категория:" 
                               VerticalAlignment="Center" Margin="0,0,0,15" 
                               Foreground="#F0F6FC" FontWeight="SemiBold"/>
                    <ComboBox x:Name="CategoryComboBox" Grid.Row="1" Grid.Column="1" 
                              Style="{StaticResource DarkComboBox}" Margin="0,0,0,15"
                              IsEditable="True" Text="Выберите или введите категорию">
                        <ComboBoxItem Content="Процессоры" Style="{StaticResource DarkComboBoxItem}"/>
                        <ComboBoxItem Content="Видеокарты" Style="{StaticResource DarkComboBoxItem}"/>
                        <ComboBoxItem Content="Память" Style="{StaticResource DarkComboBoxItem}"/>
                        <ComboBoxItem Content="Накопители" Style="{StaticResource DarkComboBoxItem}"/>
                        <ComboBoxItem Content="Материнские платы" Style="{StaticResource DarkComboBoxItem}"/>
                        <ComboBoxItem Content="Блоки питания" Style="{StaticResource DarkComboBoxItem}"/>
                        <ComboBoxItem Content="Корпуса" Style="{StaticResource DarkComboBoxItem}"/>
                        <ComboBoxItem Content="Охлаждение" Style="{StaticResource DarkComboBoxItem}"/>
                    </ComboBox>
                    
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Бренд:" 
                               VerticalAlignment="Center" Margin="0,0,0,15" 
                               Foreground="#F0F6FC" FontWeight="SemiBold"/>
                    <TextBox x:Name="BrandTextBox" Grid.Row="2" Grid.Column="1" 
                             Style="{StaticResource DarkTextBox}" Margin="0,0,0,15"
                             GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"
                             Foreground="#C9D1D9" Text="Введите бренд производителя"/>
                    
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Модель:" 
                               VerticalAlignment="Center" 
                               Foreground="#F0F6FC" FontWeight="SemiBold"/>
                    <TextBox x:Name="ModelTextBox" Grid.Row="3" Grid.Column="1" 
                             Style="{StaticResource DarkTextBox}"
                             GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"
                             Foreground="#C9D1D9" Text="Введите модель компонента"/>
                </Grid>
                
                <!-- Цена и количество -->
                <TextBlock Text="Цена и количество" FontSize="16" FontWeight="Bold" 
                           Margin="0,0,0,15" Foreground="#F0F6FC"/>
                
                <Grid Margin="0,0,0,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Цена (₽):" 
                               VerticalAlignment="Center" Margin="0,0,10,15" 
                               Foreground="#F0F6FC" FontWeight="SemiBold"/>
                    <TextBox x:Name="PriceTextBox" Grid.Row="0" Grid.Column="1" 
                             Style="{StaticResource DarkTextBox}" Margin="0,0,15,15"
                             GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"
                             Foreground="#C9D1D9" Text="Введите цену в рублях"/>
                    
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Количество:" 
                               VerticalAlignment="Center" Margin="0,0,10,15" 
                               Foreground="#F0F6FC" FontWeight="SemiBold"/>
                    <TextBox x:Name="StockQuantityTextBox" Grid.Row="0" Grid.Column="3" 
                             Style="{StaticResource DarkTextBox}" Margin="0,0,0,15"
                             GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"
                             Foreground="#C9D1D9" Text="Введите количество"/>
                    
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Мин. остаток:" 
                               VerticalAlignment="Center" Margin="0,0,10,0" 
                               Foreground="#F0F6FC" FontWeight="SemiBold"/>
                    <TextBox x:Name="MinStockLevelTextBox" Grid.Row="1" Grid.Column="1" 
                             Style="{StaticResource DarkTextBox}" Margin="0,0,15,0"
                             GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"
                             Foreground="#C9D1D9" Text="Минимальный остаток"/>
                </Grid>
                
                <!-- Описание -->
                <TextBlock Text="Описание" FontSize="16" FontWeight="Bold" 
                           Margin="0,0,0,15" Foreground="#F0F6FC"/>
                
                <TextBox x:Name="DescriptionTextBox" 
                         Style="{StaticResource DarkTextBox}" Height="80" Margin="0,0,0,20"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"
                         Foreground="#C9D1D9" Text="Введите описание компонента (необязательно)"/>
                
                <!-- Предварительный просмотр -->
                <Border Style="{StaticResource DarkBorder}" Padding="15">
                    <StackPanel>
                        <TextBlock Text="🛠️ Предварительный просмотр" FontSize="14" FontWeight="Bold" 
                                   Margin="0,0,0,10" Foreground="#58A6FF"/>
                        <TextBlock x:Name="PreviewText" Text="Компонент будет добавлен в каталог" 
                                   Foreground="#C9D1D9" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,0">
            <Button Content="💾 Добавить компонент" Margin="0,0,15,0"
                    Style="{StaticResource DarkButton}"
                    Click="AddComponent_Click"/>
            <Button Content="❌ Отмена"
                    Style="{StaticResource DarkButton}"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>