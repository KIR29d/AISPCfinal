<Window x:Class="AISPC.Views.Dialogs.CustomMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сообщение" Height="250" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent">
    
    <Border Background="#0D1117" BorderBrush="#30363D" BorderThickness="2" CornerRadius="8">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Заголовок -->
            <Grid Grid.Row="0" Margin="0,0,0,15">
                <TextBlock x:Name="TitleTextBlock" Text="Сообщение" 
                           FontSize="18" FontWeight="Bold" 
                           Foreground="#F0F6FC" HorizontalAlignment="Left"/>
                <Button Content="✕" Width="30" Height="30" 
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#8B949E" FontSize="16"
                        Click="Close_Click" Cursor="Hand"/>
            </Grid>
            
            <!-- Иконка и сообщение -->
            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock x:Name="IconTextBlock" Grid.Column="0" 
                           FontSize="32" Margin="0,0,15,0"
                           VerticalAlignment="Top"/>
                
                <TextBlock x:Name="MessageTextBlock" Grid.Column="1" 
                           Text="Сообщение" FontSize="14" 
                           Foreground="#F0F6FC" TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
            </Grid>
            
            <!-- Кнопки -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" 
                        HorizontalAlignment="Right">
                <Button x:Name="OkButton" Content="OK" Width="80" Height="35" 
                        Margin="0,0,10,0" Style="{StaticResource DarkButton}"
                        Click="Ok_Click"/>
                <Button x:Name="CancelButton" Content="Отмена" Width="80" Height="35" 
                        Style="{StaticResource DarkButton}" Background="#21262D"
                        Click="Cancel_Click" Visibility="Collapsed"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>