<Window x:Class="AISPC.Views.Dialogs.WarehouseOperationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Складская операция" Height="650" Width="750"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        MinHeight="600" MinWidth="700"
        Style="{StaticResource DarkWindow}">
    
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="📦 Складская операция" 
                   FontSize="22" FontWeight="Bold" Margin="0,0,0,25"
                   Foreground="#F0F6FC" HorizontalAlignment="Center"/>
        
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Тип операции -->
                <TextBlock Text="Тип операции" FontSize="16" FontWeight="Bold" 
                           Margin="0,0,0,15" Foreground="#F0F6FC"/>
                
                <ComboBox x:Name="OperationTypeComboBox" Margin="0,0,0,25" Height="45"
                          Style="{StaticResource DarkComboBox}"
                          SelectionChanged="OperationTypeComboBox_SelectionChanged">
                    <ComboBoxItem Content="📥 Поступление" Style="{StaticResource DarkComboBoxItem}"/>
                    <ComboBoxItem Content="📤 Списание" Style="{StaticResource DarkComboBoxItem}"/>
                    <ComboBoxItem Content="🔄 Перемещение" Style="{StaticResource DarkComboBoxItem}"/>
                    <ComboBoxItem Content="📊 Инвентаризация" Style="{StaticResource DarkComboBoxItem}"/>
                </ComboBox>
                
                <!-- Компонент -->
                <TextBlock Text="Выбор компонента" FontSize="16" FontWeight="Bold" 
                           Margin="0,0,0,15" Foreground="#F0F6FC"/>
                
                <ComboBox x:Name="ComponentComboBox" Margin="0,0,0,15" Height="45"
                          Style="{StaticResource DarkComboBox}"
                          DisplayMemberPath="Name" SelectedValuePath="Id"
                          SelectionChanged="ComponentComboBox_SelectionChanged"/>
                
                <!-- Текущий остаток -->
                <Border Style="{StaticResource DarkBorder}" Padding="15" Margin="0,0,0,25">
                    <StackPanel>
                        <TextBlock Text="📊 Информация о компоненте" FontSize="14" FontWeight="Bold" 
                                   Margin="0,0,0,10" Foreground="#58A6FF"/>
                        <TextBlock x:Name="CurrentStockTextBlock" Text="Выберите компонент для просмотра информации" 
                                   Foreground="#C9D1D9" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                
                <!-- Количество и детали -->
                <TextBlock Text="Детали операции" FontSize="16" FontWeight="Bold" 
                           Margin="0,0,0,15" Foreground="#F0F6FC"/>
                
                <Grid Margin="0,0,0,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="Количество:" 
                               VerticalAlignment="Center" Margin="0,0,10,0" 
                               Foreground="#F0F6FC" FontWeight="SemiBold"/>
                    <TextBox x:Name="QuantityTextBox" Grid.Column="1" 
                             Style="{StaticResource DarkTextBox}" Height="40" Margin="0,0,15,0"
                             TextChanged="QuantityTextBox_TextChanged"/>
                    
                    <TextBlock Grid.Column="2" Text="Дата операции:" 
                               VerticalAlignment="Center" Margin="0,0,10,0" 
                               Foreground="#F0F6FC" FontWeight="SemiBold"/>
                    <DatePicker x:Name="OperationDatePicker" Grid.Column="3" 
                               Style="{StaticResource DarkDatePicker}" Height="40"/>
                </Grid>
                
                <!-- Ответственный -->
                <Grid Margin="0,0,0,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="Ответственный:" 
                               VerticalAlignment="Center" Margin="0,0,10,0" 
                               Foreground="#F0F6FC" FontWeight="SemiBold"/>
                    <TextBox x:Name="ResponsibleTextBox" Grid.Column="1" 
                             Style="{StaticResource DarkTextBox}" Height="40"
                             GotFocus="ResponsibleTextBox_GotFocus" LostFocus="ResponsibleTextBox_LostFocus"
                             Foreground="#C9D1D9" Text="Введите ФИО ответственного"/>
                </Grid>
                
                <!-- Причина/Комментарий -->
                <TextBlock Text="Комментарий" FontSize="16" FontWeight="Bold" 
                           Margin="0,0,0,15" Foreground="#F0F6FC"/>
                
                <TextBox x:Name="ReasonTextBox" Height="100" Margin="0,0,0,20"
                         Style="{StaticResource DarkTextBox}"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         GotFocus="ReasonTextBox_GotFocus" LostFocus="ReasonTextBox_LostFocus"
                         Foreground="#C9D1D9" Text="Укажите причину или комментарий к операции"/>
                
                <!-- Предварительный просмотр -->
                <Border Style="{StaticResource DarkBorder}" Padding="15">
                    <StackPanel>
                        <TextBlock Text="📦 Предварительный просмотр операции" FontSize="14" FontWeight="Bold" 
                                   Margin="0,0,0,10" Foreground="#58A6FF"/>
                        <TextBlock x:Name="PreviewText" Text="Выберите тип операции и компонент" 
                                   Foreground="#C9D1D9" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        
        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,0">
            <Button Content="📦 Выполнить операцию" Margin="0,0,15,0"
                    Style="{StaticResource DarkButton}"
                    Click="Execute_Click"/>
            <Button Content="❌ Отмена"
                    Style="{StaticResource DarkButton}"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>